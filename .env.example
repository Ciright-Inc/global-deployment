# Keyra Global Deployment — standalone public site
#
# Copy to `.env` and point DATABASE_URL at the same Postgres as the main Keyra app.

# Shared deployment registry database (same as Keyra root).
DATABASE_URL="postgresql://keyra:keyra@localhost:5432/keyra?schema=public"

# This site's public origin (production: https://governments.keyra.ie).
NEXT_PUBLIC_GLOBAL_DEPLOYMENT_URL="http://localhost:3050"

# Main Keyra marketing site (for ecosystem links).
NEXT_PUBLIC_KEYRA_SITE_URL="http://localhost:3030"

# Canonical keyra.ie origin for public CMS APIs (footer, etc.).
NEXT_PUBLIC_KEYRA_MARKETING_ORIGIN="https://keyra.ie"

# Optional override for 9-dot launcher app list (defaults: dev proxy → Keyra :3030, prod → keyra.ie API)
# NEXT_PUBLIC_KEYRA_LAUNCHER_APPS_URL=https://keyra.ie/api/deployments/apps/launcher

# Shared SimSecure auth (same as Keyra — session cookie must use parent domain in prod, e.g. .keyra.ie).
NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL="https://auth.keyra.ie"

# ElevenLabs ConvAI widget (same agent as keyra.ie — allow this origin in agent Security tab)
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=agent_4401kbnjtddpfsc9b97n73asggc1

# Optional: server access verification emails
# MANDRILL_API_KEY=""
# MANDRILL_FROM_EMAIL=""
